---
import Layout from '../layouts/Layout.astro';
import Lightbox from '../components/Lightbox.astro';
import { getPaintings } from '../lib/content';

const paintings = await getPaintings();
const gallery = paintings.flatMap((a) => a.gallery);
const intro = paintings[0]?.description ?? [
  'Original paintings to bring colour, character, and a personal story to your walls.',
];
---

<Layout
  title="Paintings"
  description="Original paintings by NK Spaces — ready works and custom commissions."
>
  <section class="container-x py-16 md:py-20">
    <header class="mb-12 max-w-2xl">
      <p class="text-sm uppercase tracking-[0.25em] text-clay">Art</p>
      <h1 class="mt-3 text-4xl md:text-5xl">Paintings</h1>
      <div class="mt-4 space-y-4 text-lg leading-relaxed text-muted">
        {intro.map((p) => <p>{p}</p>)}
      </div>
    </header>

    {gallery.length > 0 ? (
      <Lightbox images={gallery.map((g) => ({ src: typeof g.src === 'string' ? g.src : '', alt: g.alt }))} />
    ) : (
      <p class="rounded-xl border border-dashed border-sand bg-sand/20 px-6 py-12 text-center text-muted">
        New paintings are on the way — check back soon.
      </p>
    )}

    <div class="mt-16 rounded-2xl bg-sand/50 px-8 py-12 text-center">
      <h2 class="text-2xl md:text-3xl">Want a piece for your space?</h2>
      <p class="mx-auto mt-3 max-w-lg text-muted">Original works and custom commissions in sizes and palettes to suit your home.</p>
      <a href="/contact" class="mt-6 inline-block rounded-full bg-ink px-7 py-3 text-sm uppercase tracking-widest text-cream transition hover:bg-clay-dark">Enquire now</a>
    </div>
  </section>
</Layout>
