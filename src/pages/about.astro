---
import Layout from '../layouts/Layout.astro';
import { getSiteSettings } from '../lib/content';
const settings = await getSiteSettings();
const photo = typeof settings.ownerPhoto === 'string' ? settings.ownerPhoto : '';
---

<Layout title="About" description={settings.about[0]}>
  <section class="container-x py-16 md:py-20">
    <div class="grid items-start gap-12 md:grid-cols-2">
      <div class="overflow-hidden rounded-2xl bg-sand">
        <img src={photo} alt={`${settings.founder}, founder of ${settings.name}`} class="aspect-[4/5] w-full object-cover" />
      </div>

      <div>
        <p class="text-sm uppercase tracking-[0.25em] text-clay">About</p>
        <h1 class="mt-3 text-4xl md:text-5xl">{settings.aboutHeadline}</h1>
        <div class="mt-6 space-y-4 text-lg leading-relaxed text-muted">
          {settings.about.map((p) => <p>{p}</p>)}
        </div>
        <a href="/contact" class="mt-8 inline-block rounded-full bg-ink px-7 py-3 text-sm uppercase tracking-widest text-cream transition hover:bg-clay-dark">Work with {settings.founder}</a>
      </div>
    </div>

    <!-- Services -->
    <div class="mt-24">
      <h2 class="text-3xl md:text-4xl">What we do</h2>
      <div class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {settings.services.map((s) => (
          <div class="border-t border-sand pt-5">
            <h3 class="font-serif text-xl text-ink">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
