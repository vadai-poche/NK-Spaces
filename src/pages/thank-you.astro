---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank you">
  <section class="container-x flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
    <p class="text-sm uppercase tracking-[0.25em] text-clay">Enquiry received</p>
    <h1 class="mt-4 text-4xl md:text-5xl">Thank you!</h1>
    <p class="mt-5 max-w-md text-muted">
      Your message is on its way. We’ll be in touch by email very soon to talk about your project.
    </p>
    <a href="/" class="mt-8 inline-block rounded-full bg-ink px-7 py-3 text-sm uppercase tracking-widest text-cream transition hover:bg-clay-dark">Back to home</a>
  </section>
</Layout>
