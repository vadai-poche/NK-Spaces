---
import Layout from '../../layouts/Layout.astro';
import BeforeAfterSlider from '../../components/BeforeAfterSlider.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getProjects } from '../../lib/content';

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const meta = [project.category, project.location, project.year].filter(Boolean).join(' · ');
const hasBeforeAfter =
  typeof project.beforeImage === 'string' && typeof project.afterImage === 'string';
---

<Layout title={project.title} description={project.description[0]}>
  <article class="container-x py-16 md:py-20">
    <a href="/projects" class="text-sm uppercase tracking-widest text-muted hover:text-clay">← All projects</a>

    <header class="mt-6 max-w-3xl">
      <h1 class="text-4xl md:text-5xl">{project.title}</h1>
      {meta && <p class="mt-3 text-sm uppercase tracking-widest text-clay">{meta}</p>}
      <div class="mt-6 space-y-4 text-lg leading-relaxed text-muted">
        {project.description.map((p) => <p>{p}</p>)}
      </div>
    </header>

    {project.tourVideo && (
      <section class="mt-12">
        <h2 class="mb-4 text-2xl">Full House Tour</h2>
        <div class="flex justify-center rounded-xl bg-ink py-4">
          <video
            src={project.tourVideo}
            controls
            preload="metadata"
            playsinline
            class="max-h-[75vh] w-auto max-w-full rounded-lg"
          ></video>
        </div>
      </section>
    )}

    {hasBeforeAfter && (
      <section class="mt-12">
        <h2 class="mb-4 text-2xl">Before &amp; After</h2>
        <BeforeAfterSlider
          before={project.beforeImage as string}
          after={project.afterImage as string}
          alt={project.title}
        />
        <p class="mt-3 text-sm text-muted">Drag the handle to compare.</p>
      </section>
    )}

    <section class="mt-14">
      <Lightbox images={project.gallery.map((g) => ({ src: typeof g.src === 'string' ? g.src : '', alt: g.alt }))} />
    </section>

    <div class="mt-16 rounded-2xl bg-sand/50 px-8 py-12 text-center">
      <h2 class="text-2xl md:text-3xl">Love this style?</h2>
      <p class="mx-auto mt-3 max-w-lg text-muted">Let’s talk about creating something just as special for your space.</p>
      <a href="/contact" class="mt-6 inline-block rounded-full bg-ink px-7 py-3 text-sm uppercase tracking-widest text-cream transition hover:bg-clay-dark">Enquire now</a>
    </div>
  </article>
</Layout>
