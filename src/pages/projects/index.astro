---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getProjects } from '../../lib/content';

const projects = await getProjects();
---

<Layout title="Projects" description="A selection of interior design projects by NK Spaces.">
  <section class="container-x py-16 md:py-20">
    <header class="mb-12 max-w-2xl">
      <p class="text-sm uppercase tracking-[0.25em] text-clay">Portfolio</p>
      <h1 class="mt-3 text-4xl md:text-5xl">Projects</h1>
      <p class="mt-4 text-muted">A selection of homes and spaces we’ve designed, styled, and transformed.</p>
    </header>

    <div class="grid gap-x-6 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => <ProjectCard project={p} />)}
    </div>
  </section>
</Layout>
